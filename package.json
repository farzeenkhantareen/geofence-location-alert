  "dependencies": {
    "@expo/ui": "~56.0.18",
    "@react-navigation/native": "^7.3.3",
    "@react-navigation/native-stack": "^7.17.5",
    "expo": "~56.0.12",
    "expo-constants": "~56.0.18",
    "expo-device": "~56.0.4",
    "expo-font": "~56.0.7",
    "expo-glass-effect": "~56.0.4",
    "expo-image": "~56.0.11",
    "expo-linking": "~56.0.14",
    "expo-location": "~56.0.18",
    "expo-notifications": "~56.0.18",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-system-ui": "~56.0.5",
    "expo-task-manager": "~56.0.19",
    "expo-web-browser": "~56.0.5",
    "geolib": "^3.3.14",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~56.0.4",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --watchAll",
    "lint": "expo lint",
    "eas-prod-android": "eas build --profile production --platform android",
    "prebuild-android": "expo prebuild --platform android",
    "prebuild-ios": "expo prebuild --platform ios",
    "assemble-debug": "expo prebuild --clean && cd android && ./gradlew assembleDebug --stacktrace",
    "assemble-release": "expo prebuild --clean && cd android && ./gradlew assembleRelease --stacktrace",
    "bundle-release-mac": "expo prebuild --clean && bash signing-config.sh && cd android && ./gradlew bundleRelease --stacktrace",
    "bundle-release-windows": "expo prebuild --clean && powershell -ExecutionPolicy Bypass -File signing-config.ps1 && cd android && ./gradlew bundleRelease --stacktrace",
    "reset-project": "node ./scripts/reset-project.js"
  },
  "private": true
}